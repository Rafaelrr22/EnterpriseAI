#######################################
# Authentication
#######################################

### Register Admin
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "fullName": "Admin",
  "email": "admin@enterpriseai.local",
  "password": "Password123!"
}

###

### Register Maria
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "fullName": "Maria",
  "email": "maria@enterpriseai.local",
  "password": "Password123!"
}

###

### Register Duplicate User
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "fullName": "Admin Again",
  "email": "admin@enterpriseai.local",
  "password": "Password123!"
}

###

### Login Admin
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@enterpriseai.local",
  "password": "Password123!"
}

###

### Login Maria
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "maria@enterpriseai.local",
  "password": "Password123!"
}

#######################################
# User
#######################################

### Current User
GET {{host}}/api/users/me
Authorization: Bearer {{adminJwt}}

#######################################
# Conversations
#######################################

### Create Conversation
POST {{host}}/api/conversations
Authorization: Bearer {{adminJwt}}
Content-Type: application/json

{
  "title": "Primeira conversa"
}

###

### List Conversations (Admin)
GET {{host}}/api/conversations
Authorization: Bearer {{adminJwt}}

###

### List Conversations (Maria)
GET {{host}}/api/conversations
Authorization: Bearer {{mariaJwt}}

#######################################
# Messages
#######################################

### Send Message (Admin)
POST {{host}}/api/conversations/{{adminConversation}}/messages
Authorization: Bearer {{adminJwt}}
Content-Type: application/json

{
  "content": "Olá, como estás?"
}

###

### Get Messages (Admin)
GET {{host}}/api/conversations/{{adminConversation}}/messages
Authorization: Bearer {{adminJwt}}

###

### Get Messages (Maria - Unauthorized)
GET {{host}}/api/conversations/{{adminConversation}}/messages
Authorization: Bearer {{mariaJwt}}

#######################################
# AI
#######################################

### AI Test
POST {{host}}/api/ai/test
Content-Type: application/json

{
  "prompt": "Quem és?"
}

